{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Toddler Claude",
  "version": "0.1.0",
  "identifier": "com.waltermuurmans.toddlerclaude",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Toddler Claude",
        "width": 1100,
        "height": 760,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc:; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' ipc: tauri: https://api.machines.dev https://api.fly.io https://api.github.com https://github.com wss://*.fly.dev",
      "assetProtocol": { "enable": false }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "Walther Muurmans",
    "shortDescription": "Toddler-proof remote Claude sessions",
    "longDescription": "One-click ephemeral remote Claude Code sessions with subscription auth, isolated Fly.io VMs, and hardened GitHub repo access.",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {}
}
